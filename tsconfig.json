{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "./app/static/dist",
    "rootDir": "./app/static/src/ts",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["app/static/src/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
